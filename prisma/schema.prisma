datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

enum Role {
  REQUESTOR
  AGGREGATOR
  APPROVER
  SUPER_ADMIN
}

enum ReservationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum StageStatus {
  REQUESTED
  APPROVED
  REJECTED
}

model User {
  id                   Int                @id @default(autoincrement())
  name                 String
  email                String             @unique
  password             String
  role                 Role               @default(REQUESTOR)
  organization         String?
  phone                String?
  
  // Relations
  reservations         Reservation[]
  approvedWorkflows    ApprovalWorkflow[] @relation("Approver")
  logs                 Log[]
  reports              Report[]
  notifications        Notification[]
  managedRooms         Room[]             @relation("RoomApprover")
}

model Room {
  id           Int            @id @default(autoincrement())
  name         String
  location     String
  capacity     Int
  approverId   Int?
  
  // Relations
  approver     User?          @relation("RoomApprover", fields: [approverId], references: [id])
  facilities   RoomFacility[]
  schedules    Schedule[]
  reservations Reservation[]
}

model Facility {
  id           Int            @id @default(autoincrement())
  name         String
  description  String?
  
  // Relations
  rooms        RoomFacility[]
}

model RoomFacility {
  roomId       Int
  facilityId   Int
  
  room         Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  facility     Facility   @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  
  @@id([roomId, facilityId])
}

model Schedule {
  id           Int            @id @default(autoincrement())
  roomId       Int
  startTime    DateTime
  endTime      DateTime
  isBlocked    Boolean        @default(false)
  
  room         Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  reservations Reservation[]
}

model Reservation {
  id             Int                  @id @default(autoincrement())
  userId         Int
  roomId         Int
  scheduleId     Int
  status         ReservationStatus    @default(PENDING)
  purpose        String
  
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  room           Room                 @relation(fields: [roomId], references: [id], onDelete: Cascade)
  schedule       Schedule             @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  
  approvalStages ApprovalWorkflow[]
}

model ApprovalWorkflow {
  id             Int             @id @default(autoincrement())
  reservationId  Int
  stage          StageStatus
  approverId     Int
  status         ReservationStatus
  notes          String?
  approvedAt     DateTime?
  
  reservation    Reservation     @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  approver       User            @relation("Approver", fields: [approverId], references: [id], onDelete: Cascade)
}

model Log {
  id             Int       @id @default(autoincrement())
  userId         Int
  action         String
  timestamp      DateTime  @default(now())
  
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id             Int       @id @default(autoincrement())
  generatedById  Int
  content        String
  generatedAt    DateTime  @default(now())
  
  generatedBy    User      @relation(fields: [generatedById], references: [id], onDelete: Cascade)
}

model Notification {
  id             Int       @id @default(autoincrement())
  userId         Int
  message        String
  link           String?
  timestamp      DateTime  @default(now())
  
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
